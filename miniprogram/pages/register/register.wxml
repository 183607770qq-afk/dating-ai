<view class="register-page">
  <view class="register-container">
    <!-- 头部 -->
    <view class="header">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="header-title">创建咨询档案</text>
      <view class="placeholder"></view>
    </view>

    <!-- 表单区域 -->
    <view class="form-section">
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-icon">👤</text>
          <input 
            class="form-input" 
            placeholder="用户名" 
            value="{{username}}"
            bindinput="onUsernameInput"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-icon">📧</text>
          <input 
            class="form-input" 
            placeholder="邮箱" 
            value="{{email}}"
            bindinput="onEmailInput"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-icon">🔒</text>
          <input 
            class="form-input" 
            placeholder="密码" 
            password
            value="{{password}}"
            bindinput="onPasswordInput"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-icon">🔑</text>
          <input 
            class="form-input" 
            placeholder="确认密码" 
            password
            value="{{confirmPassword}}"
            bindinput="onConfirmPasswordInput"
          />
        </view>
      </view>

      <!-- 注册按钮 -->
      <view 
        class="register-btn {{!isFormValid || loading ? 'disabled' : ''}}"
        bindtap="handleRegister"
      >
        <text class="btn-text">{{loading ? '注册中...' : '创建账号'}}</text>
      </view>

      <!-- 登录链接 -->
      <view class="login-link" bindtap="goToLogin">
        <text class="link-text">已有账号？立即登录</text>
      </view>
    </view>
  </view>
</view>
