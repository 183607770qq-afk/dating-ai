.home {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff1ec 0%, #fff8f6 46%, #f7f3ef 100%);
}

.header {
  padding: 64rpx 36rpx 42rpx;
}

.top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  display: block;
  color: #b9786c;
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.logo-text {
  display: block;
  font-size: 58rpx;
  font-weight: 800;
  color: #2f2928;
}

.user-chip,
.login-pill {
  min-width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #d85c5c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 34rpx rgba(122, 80, 70, 0.12);
}

.login-pill {
  padding: 0 26rpx;
}

.subtitle {
  margin-top: 26rpx;
  max-width: 620rpx;
  font-size: 32rpx;
  line-height: 1.55;
  color: #5f5551;
  font-weight: 600;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.primary-action,
.ghost-action {
  height: 86rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-action {
  flex: 1;
  background: #d85c5c;
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(216, 92, 92, 0.26);
}

.ghost-action {
  width: 176rpx;
  color: #d85c5c;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(216, 92, 92, 0.18);
}

.main-content {
  padding: 0 28rpx 32rpx;
}

.insight-panel {
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(90, 64, 56, 0.08);
  margin-bottom: 24rpx;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.panel-title {
  color: #2f2928;
  font-size: 30rpx;
  font-weight: 800;
}

.panel-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1ec;
  color: #b9786c;
  font-size: 22rpx;
  font-weight: 700;
}

.panel-copy {
  color: #6b625e;
  font-size: 27rpx;
  line-height: 1.7;
}

.features {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  min-height: 132rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(90, 64, 56, 0.06);
}

.feature-card:active,
.primary-action:active,
.ghost-action:active {
  transform: scale(0.98);
}

.feature-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 22rpx;
}

.chat-icon {
  background: #ffe7df;
}

.knowledge-icon {
  background: #f1eadf;
}

.subscription-icon {
  background: #e8f1ee;
}

.icon-text {
  font-size: 28rpx;
  color: #8f4a43;
  font-weight: 800;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #2f2928;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #8f8580;
  line-height: 1.45;
}

.feature-arrow {
  font-size: 32rpx;
  color: #d8c8c0;
  margin-left: 16rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.quick-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 92rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(143, 74, 67, 0.08);
}

.quick-action:active {
  background: #ffffff;
}

.quick-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #fff1ec;
  color: #b65d55;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.quick-text {
  font-size: 26rpx;
  color: #4c4441;
  font-weight: 700;
}

.footer {
  text-align: center;
  padding: 20rpx 32rpx 46rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #a99d98;
}
