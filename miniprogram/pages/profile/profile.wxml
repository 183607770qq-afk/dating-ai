<view class="profile-page">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view wx:if="{{isLoggedIn}}" class="user-info">
      <view class="avatar">
        <text class="avatar-text">{{avatarText}}</text>
      </view>
      <view class="user-detail">
        <text class="username">{{username}}</text>
        <text class="user-desc">欢迎回来</text>
      </view>
    </view>
    
    <view wx:else class="login-prompt">
      <view class="avatar guest-avatar">
        <text class="avatar-text">未</text>
      </view>
      <view class="user-detail">
        <text class="username">未登录</text>
        <text class="user-desc">登录后保存咨询记录和成长档案</text>
      </view>
      <view class="login-btn" bindtap="goToLogin">
        <text class="btn-text">立即登录</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToChat">
        <view class="menu-icon">聊</view>
        <text class="menu-text">AI情感咨询</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item">
        <view class="menu-icon">藏</view>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="goToHistory">
        <view class="menu-icon">记</view>
        <text class="menu-text">咨询记录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group" wx:if="{{isLoggedIn}}">
      <view class="menu-item">
        <view class="menu-icon">设</view>
        <text class="menu-text">账号设置</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item">
        <view class="menu-icon">知</view>
        <text class="menu-text">消息通知</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item">
        <view class="menu-icon">帮</view>
        <text class="menu-text">帮助中心</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item">
        <view class="menu-icon">关</view>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="menu-group" wx:if="{{isLoggedIn}}">
      <view class="menu-item logout-item" bindtap="handleLogout">
        <view class="menu-icon">退</view>
        <text class="menu-text logout-text">退出登录</text>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text class="footer-text">脱单AI v1.0.0 · 真诚、尊重、清晰表达</text>
  </view>
</view>
