<view class="login-page">
  <view class="login-container">
    <view class="logo-section">
      <view class="logo-icon">AI</view>
      <text class="logo-text">脱单AI</text>
      <text class="logo-desc">把关系里的犹豫，整理成清晰的下一步</text>
    </view>

    <view class="form-section">
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-icon">👤</text>
          <input 
            class="form-input" 
            placeholder="用户名" 
            value="{{username}}"
            bindinput="onUsernameInput"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-icon">🔒</text>
          <input 
            class="form-input" 
            placeholder="密码" 
            password
            value="{{password}}"
            bindinput="onPasswordInput"
          />
        </view>
      </view>

      <view 
        class="login-btn {{!username.trim() || !password.trim() || loading ? 'disabled' : ''}}"
        bindtap="handleLogin"
      >
        <text class="btn-text">{{loading ? '登录中...' : '登录并继续咨询'}}</text>
      </view>

      <view class="register-link" bindtap="goToRegister">
        <text class="link-text">还没有账号？立即注册</text>
      </view>
    </view>

    <view class="test-account">
      <text class="test-title">体验账号</text>
      <view class="test-info">
        <text>用户名：user</text>
        <text>密码：password</text>
      </view>
    </view>
  </view>
</view>
