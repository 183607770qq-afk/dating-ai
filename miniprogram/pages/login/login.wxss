.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff1ec 0%, #fff8f6 58%, #f7f3ef 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx 34rpx;
  box-sizing: border-box;
}

.login-container {
  width: 100%;
  max-width: 640rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 56rpx 38rpx 36rpx;
  box-shadow: 0 22rpx 52rpx rgba(90, 64, 56, 0.12);
}

.logo-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.logo-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  margin: 0 auto 22rpx;
  background: #d85c5c;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 34rpx rgba(216, 92, 92, 0.25);
}

.logo-text {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #2f2928;
  margin-bottom: 14rpx;
}

.logo-desc {
  display: block;
  max-width: 480rpx;
  margin: 0 auto;
  font-size: 26rpx;
  line-height: 1.55;
  color: #7d716c;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #fff8f6;
  border: 1rpx solid #f0ddd6;
  border-radius: 22rpx;
  padding: 0 26rpx;
  height: 92rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 18rpx;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 29rpx;
  color: #2f2928;
}

.login-btn {
  background: #d85c5c;
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  box-shadow: 0 16rpx 34rpx rgba(216, 92, 92, 0.24);
}

.login-btn.disabled {
  opacity: 0.46;
  box-shadow: none;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.register-link {
  text-align: center;
  margin-top: 8rpx;
}

.link-text {
  font-size: 26rpx;
  color: #b65d55;
  font-weight: 700;
}

.test-account {
  margin-top: 44rpx;
  padding: 24rpx;
  background: #f7f3ef;
  border-radius: 18rpx;
}

.test-title {
  display: block;
  font-size: 24rpx;
  color: #6b625e;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.test-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.test-info text {
  font-size: 23rpx;
  color: #8f8580;
}
